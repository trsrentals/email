{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/backend.py",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=backend.py" },
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
